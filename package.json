      "REQUEST_WEATHER",
      "TripName", "StartName", "DestName",
      "Waypoint1", "Waypoint2", "Waypoint3", "Waypoint4", "Waypoint5",
      "CurrentDistance", "ProgressUnit", "TripDay",
      "ShowWeather", "TempUnit",
      "CalcTotalDist",
      "CalcDayDist1", "CalcDayDist2", "CalcDayDist3", "CalcDayDist4", "CalcDayDist5"
    ],
    "resources": { "media": [] }
